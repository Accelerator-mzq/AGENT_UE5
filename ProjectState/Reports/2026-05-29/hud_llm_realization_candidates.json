            ]
          },
          "satisfies_bounds": true,
          "estimated_complexity": "low"
        },
        {
          "candidate_id": "hud.density.balanced",
          "name": "Balanced Info Display",
          "description": "在最小集合基础上增加玩家位置索引（当前格编号）和入狱状态图标。提供平衡的可读性与信息丰富度。",
          "trade_offs": {
            "pros": [
