{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Compiler Session",
  "description": "Compiler Pipeline Orchestrator 的会话状态文件",
  "type": "object",
  "required": [
    "session_id",
    "created_at",
    "gdd_path",
    "target_phase",
    "output_dir",
    "current_stage",
    "stage_outputs",
    "status"
  ],
  "properties": {
    "session_id": {
      "type": "string",
      "format": "uuid",
      "description": "会话唯一标识"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "会话创建时间（ISO 8601）"
    },
    "gdd_path": {
      "type": "string",
      "description": "输入 GDD 路径"
    },
    "target_phase": {
      "type": "string",
      "description": "目标阶段标识"
    },
    "output_dir": {
      "type": "string",
      "description": "本次 pipeline 产物输出目录"
    },
    "current_stage": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5,
      "description": "当前所处阶段（1-5）"
    },
    "stage_outputs": {
      "type": "object",
      "description": "已完成阶段的产物路径映射",
      "patternProperties": {
        "^stage_[1-5]$": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "status": {
      "type": "string",
      "enum": ["pending", "running", "completed", "failed"],
      "description": "会话状态"
    }
  },
  "additionalProperties": false
}
