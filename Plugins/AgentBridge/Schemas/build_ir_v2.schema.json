{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Phase 11 Build IR v2",
  "description": "Stage 6 输出：Build IR v2，要求每个 build step 内嵌 naming_resolution_log。",
  "type": "object",
  "required": [
    "ir_version",
    "ir_id",
    "source_review_id",
    "source_contract_id",
    "phase_scope",
    "build_steps",
    "validation_ir",
    "lowering_report",
    "metadata"
  ],
  "properties": {
    "ir_version": {
      "type": "string",
      "const": "2.0"
    },
    "ir_id": {
      "type": "string",
      "pattern": "^ir\\.[a-z0-9_\\.]+$"
    },
    "source_review_id": {
      "type": "string"
    },
    "source_contract_id": {
      "type": "string"
    },
    "phase_scope": {
      "type": "string"
    },
    "build_steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "step_id",
          "action",
          "source_skill_instance_id",
          "source_families",
          "implementation_layer",
          "target",
          "params",
          "depends_on",
          "constraints_applied",
          "execution_hints",
          "naming_resolution_log"
        ],
        "properties": {
          "step_id": {
            "type": "string"
          },
          "action": {
            "type": "string",
            "enum": [
              "create_cpp_class",
              "create_widget_blueprint",
              "create_data_asset",
              "wire_blueprint_bridge"
            ]
          },
          "source_skill_instance_id": {
            "type": "string"
          },
          "source_families": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "implementation_layer": {
            "type": "string",
            "enum": [
              "cpp",
              "blueprint",
              "content"
            ]
          },
          "target": {
            "type": "object",
            "required": [
              "class_name",
              "file_path",
              "asset_path"
            ],
            "properties": {
              "class_name": {
                "type": "string"
              },
              "file_path": {
                "type": "string"
              },
              "asset_path": {
                "type": "string",
                "pattern": "^/Game/"
              }
            }
          },
          "params": {
            "type": "object"
          },
          "depends_on": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "constraints_applied": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "execution_hints": {
            "type": "object",
            "required": [
              "tool_preference",
              "thin_blueprint_bridge",
              "contains_provisional"
            ],
            "properties": {
              "tool_preference": {
                "type": "string",
                "enum": [
                  "mcp_bridge",
                  "cpp_code",
                  "python_editor_scripting",
                  "manual"
                ]
              },
              "thin_blueprint_bridge": {
                "type": "boolean"
              },
              "contains_provisional": {
                "type": "boolean"
              }
            }
          },
          "naming_resolution_log": {
            "type": "object",
            "minProperties": 1,
            "additionalProperties": {
              "type": "object",
              "required": [
                "resolved",
                "tier",
                "evidence"
              ],
              "properties": {
                "resolved": {
                  "type": "string"
                },
                "tier": {
                  "type": "integer",
                  "enum": [
                    1,
                    2,
                    3,
                    4
                  ]
                },
                "evidence": {
                  "type": "string"
                },
                "alternatives_considered": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    },
    "validation_ir": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "validation_id",
          "after_step",
          "check_type",
          "description",
          "expected"
        ],
        "properties": {
          "validation_id": {
            "type": "string"
          },
          "after_step": {
            "type": "string"
          },
          "check_type": {
            "type": "string",
            "enum": [
              "asset_exists",
              "cpp_symbol_exists",
              "blueprint_bridge_exists"
            ]
          },
          "description": {
            "type": "string"
          },
          "expected": {}
        }
      }
    },
    "lowering_report": {
      "type": "object",
      "required": [
        "families_received",
        "families_bound",
        "families_partially_bound",
        "unbound_requirements",
        "dependency_closure_warnings",
        "cpp_step_count",
        "blueprint_step_count",
        "baseline_step_count",
        "gameplay_step_count"
      ],
      "properties": {
        "families_received": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "families_bound": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "families_partially_bound": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "unbound_requirements": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "dependency_closure_warnings": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "type",
              "from",
              "to",
              "message"
            ],
            "properties": {
              "type": {
                "type": "string"
              },
              "from": {
                "type": "string"
              },
              "to": {
                "type": "string"
              },
              "message": {
                "type": "string"
              },
              "from_domain_type": {
                "type": "string"
              }
            }
          }
        },
        "cpp_step_count": {
          "type": "integer",
          "minimum": 0
        },
        "blueprint_step_count": {
          "type": "integer",
          "minimum": 0
        },
        "baseline_step_count": {
          "type": "integer",
          "minimum": 0
        },
        "gameplay_step_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "recovery_hints": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "metadata": {
      "type": "object",
      "required": [
        "generated_at",
        "generator",
        "project_module"
      ],
      "properties": {
        "generated_at": {
          "type": "string",
          "format": "date-time"
        },
        "generator": {
          "type": "string"
        },
        "project_module": {
          "type": "string"
        }
      }
    }
  }
}
