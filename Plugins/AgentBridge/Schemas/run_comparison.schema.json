{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Phase 11 Run Comparison",
  "description": "跨 run 的治理比较产物，覆盖 Constraint、Realization、Fragment、Build IR、Naming、Provisional 六类差异。",
  "type": "object",
  "required": [
    "comparison_version",
    "comparison_id",
    "run_a_id",
    "run_b_id",
    "compared_at",
    "summary",
    "details",
    "metadata"
  ],
  "properties": {
    "comparison_version": {
      "type": "string",
      "const": "1.0"
    },
    "comparison_id": {
      "type": "string",
      "pattern": "^cmp-[a-zA-Z0-9\\-]+$"
    },
    "run_a_id": {
      "type": "string",
      "pattern": "^run-\\d{8}-\\d{6}-[0-9a-fA-F]{4,12}$"
    },
    "run_b_id": {
      "type": "string",
      "pattern": "^run-\\d{8}-\\d{6}-[0-9a-fA-F]{4,12}$"
    },
    "compared_at": {
      "type": "string",
      "format": "date-time"
    },
    "summary": {
      "type": "object",
      "required": [
        "constraint_consistent",
        "constraint_changes",
        "realization_changes",
        "fragment_changes",
        "build_ir_changes",
        "naming_changes",
        "provisional_delta"
      ],
      "properties": {
        "constraint_consistent": {
          "type": "boolean"
        },
        "constraint_changes": {
          "type": "integer",
          "minimum": 0
        },
        "realization_changes": {
          "type": "integer",
          "minimum": 0
        },
        "fragment_changes": {
          "type": "integer",
          "minimum": 0
        },
        "build_ir_changes": {
          "type": "integer",
          "minimum": 0
        },
        "naming_changes": {
          "type": "integer",
          "minimum": 0
        },
        "provisional_delta": {
          "type": "integer"
        }
      }
    },
    "details": {
      "type": "object",
      "required": [
        "constraint_differences",
        "realization_differences",
        "fragment_differences",
        "build_ir_differences",
        "naming_differences",
        "provisional_changes"
      ],
      "properties": {
        "constraint_differences": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/change_entry"
          }
        },
        "realization_differences": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/change_entry"
          }
        },
        "fragment_differences": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/change_entry"
          }
        },
        "build_ir_differences": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/change_entry"
          }
        },
        "naming_differences": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/change_entry"
          }
        },
        "provisional_changes": {
          "type": "object",
          "required": [
            "added",
            "removed"
          ],
          "properties": {
            "added": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "removed": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "required": [
        "run_a_promotable",
        "run_b_promotable",
        "compared_artifacts",
        "cleanup_policy"
      ],
      "properties": {
        "run_a_promotable": {
          "type": "boolean"
        },
        "run_b_promotable": {
          "type": "boolean"
        },
        "compared_artifacts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "cleanup_policy": {
          "$ref": "#/definitions/cleanup_policy"
        }
      }
    }
  },
  "definitions": {
    "change_entry": {
      "type": "object",
      "required": [
        "category",
        "item_key",
        "change_type",
        "impact"
      ],
      "properties": {
        "category": {
          "type": "string",
          "enum": [
            "constraint",
            "realization",
            "fragment",
            "build_ir",
            "naming"
          ]
        },
        "item_key": {
          "type": "string"
        },
        "change_type": {
          "type": "string",
          "enum": [
            "changed",
            "added_in_run_b",
            "removed_in_run_b"
          ]
        },
        "impact": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "run_a_value": {},
        "run_b_value": {}
      }
    },
    "cleanup_policy": {
      "type": "object",
      "required": [
        "formal_runs",
        "fast_mode_runs",
        "promoted_batches",
        "failed_runs"
      ],
      "properties": {
        "formal_runs": {
          "type": "object"
        },
        "fast_mode_runs": {
          "type": "object"
        },
        "promoted_batches": {
          "type": "object"
        },
        "failed_runs": {
          "type": "object"
        }
      }
    }
  }
}
