{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Phase 11 Naming Resolution Log",
  "description": "Build IR v2 的命名审计 sidecar，逐 action 记录 resolved、tier、evidence。",
  "type": "object",
  "required": [
    "log_version",
    "source_ir_id",
    "entries",
    "summary",
    "metadata"
  ],
  "properties": {
    "log_version": {
      "type": "string",
      "const": "1.0"
    },
    "source_ir_id": {
      "type": "string"
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "ir_action_id",
          "action",
          "source_skill_instance_id",
          "naming_resolution_log"
        ],
        "properties": {
          "ir_action_id": {
            "type": "string"
          },
          "action": {
            "type": "string"
          },
          "source_skill_instance_id": {
            "type": "string"
          },
          "naming_resolution_log": {
            "type": "object",
            "minProperties": 1,
            "additionalProperties": {
              "type": "object",
              "required": [
                "resolved",
                "tier",
                "evidence"
              ],
              "properties": {
                "resolved": {
                  "type": "string"
                },
                "tier": {
                  "type": "integer",
                  "enum": [
                    1,
                    2,
                    3,
                    4
                  ]
                },
                "evidence": {
                  "type": "string"
                },
                "alternatives_considered": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "required": [
        "total_actions",
        "resolved_fields",
        "by_tier"
      ],
      "properties": {
        "total_actions": {
          "type": "integer",
          "minimum": 0
        },
        "resolved_fields": {
          "type": "integer",
          "minimum": 0
        },
        "by_tier": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "required": [
        "generated_at",
        "generator"
      ],
      "properties": {
        "generated_at": {
          "type": "string",
          "format": "date-time"
        },
        "generator": {
          "type": "string"
        }
      }
    }
  }
}
